# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
.vscode/
.claude/

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# Pre-built native binaries — generated on demand by libsmb2-scripts and
# installed here by `make checksums`. Never tracked.
/android/src/main/jniLibs/
/ios/dart_smb2/Frameworks/
/macos/dart_smb2/Frameworks/
/linux/libs/
/windows/libs/

# Build outputs / IDE noise
/android/.gradle/
/android/build/

# Integration test infrastructure: credentials, persistent volumes, and the
# cache the bootstrap script writes for the fixture.
test/integration/.env.test
test/integration/volumes/
test/integration/.bootstrap-cache.json
