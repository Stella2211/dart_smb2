# pubignore — overrides .gitignore when present; mirror dev-only paths here.

# Dart / Flutter
.dart_tool/
.flutter-plugins-dependencies
**/doc/api/
build/
coverage/
pubspec.lock

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Native build cache
.build/
.swiftpm/
/android/.gradle/
/android/build/

# Native binaries (downloaded by build)
/android/src/main/jniLibs/
/ios/dart_smb2/Frameworks/
/macos/dart_smb2/Frameworks/
/linux/libs/
/windows/libs/

# Docs
/docs/

# AI tooling
.claude/
CLAUDE.md
graphify-out/

# Tests
test/
dart_test.yaml

# Codegen config
analysis_options.yaml
ffigen.yaml

# Vendored upstream libsmb2 source (used by ffigen + native release builds;
# the published package downloads prebuilt binaries instead)
/third_party/

# Native build scripts / CI
/tool/
/.github/
