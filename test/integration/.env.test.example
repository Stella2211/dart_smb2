# Copy this file to `.env.test` and tweak as needed.
# `.env.test` is gitignored — keep credentials out of source control.

# Host port the Samba container binds on the local machine. Default 445.
# Set to e.g. 1445 if you already have an SMB server (macOS File Sharing,
# other dev container, …) listening on 445.
SMB2_HOST_PORT=445

# Share that the bootstrap creates and the tests connect to.
SMB2_SHARE=public

# Test account credentials. These are baked into the container at first
# boot via the USER1/SHARE1 environment variables.
SMB2_USER=testuser
SMB2_PASS=testpass
